# ---- Exchange ----
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# ---- Trading Mode ----
# Options: testnet | live | paused
TRADING_MODE=testnet

# ---- Strategy ----
TRADE_SYMBOL=BTCUSDT
TRADE_INTERVAL=60
EMA_FAST=21
EMA_SLOW=55
SUPERTREND_PERIOD=10
SUPERTREND_MULTIPLIER=3.0
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
RSI_ENTRY_MIN=40
RSI_ENTRY_MAX=60
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL_PERIOD=9
ATR_SL_MULTIPLIER=2.0
ATR_TP_MULTIPLIER=3.0
RISK_PER_TRADE=0.02

# ---- Risk Guards ----
MAX_DAILY_LOSS_PCT=0.05
MAX_OPEN_POSITIONS=3
MIN_ORDER_USDT=10.0

# ---- Database ----
POSTGRES_DB=tradingbot
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://trader:changeme@db:5432/tradingbot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:4200,http://localhost:80,http://frontend

# ---- Portfolio Snapshots ----
SNAPSHOT_INTERVAL_SECS=300

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Backtesting ----
BACKTEST_DEFAULT_CAPITAL=10000.0
BACKTEST_COMMISSION=0.00055
